{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=MicroATS;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "MicroATS_SecretKey_MustBeLongEnough_For_HS256",
    "Issuer": "Micro.API",
    "Audience": "Micro.Web"
  },
  "AllowedHosts": "*"
}
